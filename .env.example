# =====================================================
# LiFAC Platform - Variables d'environnement
# =====================================================
# DEV LOCAL : copiez ce fichier en .env.local et remplissez
# VERCEL    : ajoutez chaque variable dans Project Settings → Environment Variables
# =====================================================

# -----------------------------------------------------
# BASE DE DONNÉES POSTGRESQL
# -----------------------------------------------------
# DEV LOCAL  : postgresql://user:password@localhost:5432/lifac?schema=public
# VERCEL/PROD: utilisez Neon, Supabase ou Vercel Postgres
#
# IMPORTANT pour Neon en production :
# Utilisez la connection string "pooled" avec les paramètres suivants :
# postgresql://user:pwd@xxx.eu-central-1.aws.neon.tech/lifac?sslmode=require&pgbouncer=true&connect_timeout=10
#
# DATABASE_URL    : utilisée à RUNTIME (avec pooling pgbouncer)
# DIRECT_DATABASE_URL : utilisée pour les MIGRATIONS (sans pooling)
DATABASE_URL="postgresql://neondb_owner:npg_3DvybcwR4niE@ep-steep-river-adsefizo-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://neondb_owner:npg_3DvybcwR4niE@ep-steep-river-adsefizo.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# -----------------------------------------------------
# NEXTAUTH (Authentification)
# -----------------------------------------------------
# Générez un secret avec : openssl rand -base64 32
NEXTAUTH_SECRET="REMPLACER_PAR_UNE_CLE_GENEREE_ALEATOIREMENT_32_CARACTERES_MIN"

# DEV LOCAL  : http://localhost:3000
# VERCEL/PROD: https://votre-domaine.com (ou https://votre-projet.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------
# FEDAPAY (Paiements Mobile Money + Cartes)
# -----------------------------------------------------
# Obtenez vos clés sur https://fedapay.com
# Sandbox pour les tests, Live pour la production

FEDAPAY_ENVIRONMENT="sandbox"
FEDAPAY_PUBLIC_KEY="pk_sandbox_REMPLACER"
FEDAPAY_SECRET_KEY="sk_sandbox_REMPLACER"

# Secret du webhook (configuré dans le dashboard FedaPay)
FEDAPAY_WEBHOOK_SECRET="whsec_REMPLACER"

# URL de retour après paiement (DOIT être publique en prod)
# DEV LOCAL  : http://localhost:3000/donate/success
# VERCEL/PROD: https://votre-domaine.com/donate/success
FEDAPAY_CALLBACK_URL="http://localhost:3000/donate/success"

# -----------------------------------------------------
# APPLICATION
# -----------------------------------------------------
# DEV LOCAL  : http://localhost:3000
# VERCEL/PROD: https://votre-domaine.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

NEXT_PUBLIC_APP_NAME="LiFAC"
NEXT_PUBLIC_APP_DESCRIPTION="Light For All Center - Évangélisation et action humanitaire au Bénin"

# -----------------------------------------------------
# EMAIL (optionnel - pour les reçus de dons)
# -----------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="LiFAC <noreply@lifac.org>"

# -----------------------------------------------------
# STOCKAGE MEDIAS (optionnel)
# -----------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
